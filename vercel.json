{
  "version": 2,
  "framework": "nextjs",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/node"
    }
  },
  "excludeFiles": [
    "backend/**",
    "**/*.py",
    "**/__pycache__/**",
    "requirements-modal.txt"
  ]
}
